# Copy to pyserver/.env (gitignored) before running.
# Optional. Leave empty for free AkShare + BaoStock live data.
# Use TUSHARE_TOKEN=mock for offline deterministic demo data.
TUSHARE_TOKEN=

# Set to 1 in real-data test/prod to reject TUSHARE_TOKEN=mock.
STRICT_LIVE_DATA=0

# Optional paid/permissioned secondary source. Default 0 keeps signals/backtests on
# free AkShare + BaoStock paths and avoids Tushare daily_basic/report_rc limits.
MARKET_ENABLE_TUSHARE_SECONDARY=0

# Optional fallback only: pyserver strips shell HTTP(S)_PROXY by default; Eastmoney push2 is DIRECT.
# Set only when direct push2 fails but a local VPN domestic node works via explicit proxy.
# MARKET_HTTP_PROXY=http://127.0.0.1:7890
